# SMTP (Gmail recommandé)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=1

# Compte expéditeur (ex: votre Gmail)
SMTP_USERNAME=votre-adresse@gmail.com

# IMPORTANT: utilisez un MOT DE PASSE D’APPLICATION Gmail (pas votre mot de passe normal)
SMTP_PASSWORD=xxxxxxxxxxxxxxxx

# Optionnel
DEFAULT_FROM_EMAIL="MuniWorks DRC <votre-adresse@gmail.com>"

